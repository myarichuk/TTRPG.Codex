@inherits LayoutComponentBase

<div class="page">
    <header class="app-header px-3"><span class="app-title">TTRPG.Codex</span></header>
    <NavMenu />
    <main class="app-main">
        <article class="content px-4">
            <div class="container-fluid">
                @Body
