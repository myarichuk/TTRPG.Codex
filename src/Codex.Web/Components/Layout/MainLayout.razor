@inherits LayoutComponentBase
@inject Codex.Core.PluginLoader Loader
@inject Codex.Core.CodexWorld World
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject Microsoft.Extensions.Configuration.IConfiguration Config

<div class="page-wrapper">
    <NavMenu />
    <main class="main-content">
        <div class="app-container">
            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        var pluginsDir = Config["Codex:PluginsDirectory"] ?? "plugins";
        var absolutePluginsDir = Path.GetFullPath(Path.Combine(Env.ContentRootPath, pluginsDir));
        await Loader.LoadAndInitializeAsync(absolutePluginsDir, World);
    }
}
