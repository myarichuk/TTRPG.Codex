@using Codex.Web.Components.Layout

<nav class="sidebar">
    <div class="d-flex align-items-center gap-3 mb-5 px-3">
        <div style="width: 28px; height: 28px; background: var(--accent-color); border-radius: 6px;"></div>
        <span style="font-weight: 700; font-size: 1.1rem; letter-spacing: -0.5px;">CODEX</span>
    </div>
    
    <div class="mb-4">
        <p class="text-tertiary small px-3 mb-2" style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase;">Library</p>
        <NavLink href="" class="nav-link" Match="NavLinkMatch.All">
            <LucideIcon IconName="compass" />
            <span>Overview</span>
        </NavLink>
        <AuthorizeView>
            <Authorized>
                <NavLink href="campaigns" class="nav-link">
                    <LucideIcon IconName="swords" />
                    <span>Campaigns</span>
                </NavLink>
            </Authorized>
        </AuthorizeView>
        <NavLink href="grimoire" class="nav-link">
            <LucideIcon IconName="book-marked" />
            <span>Grimoire</span>
        </NavLink>
    </div>

    <div>
        <p class="text-tertiary small px-3 mb-2" style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase;">System</p>
        <NavLink href="demo" class="nav-link">
            <LucideIcon IconName="users-2" />
            <span>Players</span>
        </NavLink>
        <AuthorizeView>
            <Authorized>
                <NavLink href="settings" class="nav-link">
                    <LucideIcon IconName="settings-2" />
                    <span>Configuration</span>
                </NavLink>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="nav-link mt-4 text-primary opacity-75">
                    <LucideIcon IconName="log-in" />
                    <span>Sign In</span>
                </a>
            </NotAuthorized>
        </AuthorizeView>
    </div>

    <div class="mt-auto px-3 pb-4">
        <AuthorizeView>
            <Authorized>
                @{
                    var email = context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
                    var username = context.User.Identity?.Name ?? "User";
                    var gravatarUrl = string.IsNullOrEmpty(email)
                        ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(username)}&background=0D8ABC&color=fff&rounded=true"
                        : $"https://www.gravatar.com/avatar/{GetMd5Hash(email.Trim().ToLowerInvariant())}?d=identicon&s=40";
                }
                <div class="d-flex align-items-center gap-3 p-3 rounded" style="background-color: var(--fluent-surface-secondary); border: 1px solid var(--fluent-border); box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                    <img src="@gravatarUrl" alt="User Avatar" class="rounded-circle" style="width: 36px; height: 36px; object-fit: cover; border: 2px solid var(--fluent-border-strong);" />
                    <div class="d-flex flex-column text-truncate flex-grow-1">
                        <span class="small fw-semibold text-truncate" style="color: var(--text-primary);">@username</span>
                        <a href="/logout" class="text-danger small text-decoration-none opacity-75 hover-opacity-100" style="font-size: 0.75rem; transition: var(--transition-base);">Sign Out</a>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private static string GetMd5Hash(string input)
    {
        using (var md5 = System.Security.Cryptography.MD5.Create())
        {
            var bytes = System.Text.Encoding.UTF8.GetBytes(input);
            var hash = md5.ComputeHash(bytes);
            return BitConverter.ToString(hash).Replace("-", "").ToLowerInvariant();
        }
    }
}
