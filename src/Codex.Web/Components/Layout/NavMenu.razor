@using Codex.Web.Components.Layout

<nav class="sidebar">
    <div class="d-flex align-items-center gap-3 mb-5 px-3">
        <div style="width: 32px; height: 32px; background: var(--accent-color); border-radius: 8px; display: grid; place-items: center;">
            <LucideIcon IconName="scroll" Size="18" Class="text-white" />
        </div>
        <span style="font-weight: 800; font-size: 1.2rem; letter-spacing: -0.5px;">CODEX</span>
    </div>
    
    <div class="nav-section-label">Library</div>
    <NavLink href="" class="nav-link" Match="NavLinkMatch.All">
        <LucideIcon IconName="layout-grid" Size="18" />
        <span>Overview</span>
    </NavLink>
    <AuthorizeView>
        <Authorized>
            <NavLink href="campaigns" class="nav-link">
                <LucideIcon IconName="map" Size="18" />
                <span>Campaigns</span>
            </NavLink>
        </Authorized>
    </AuthorizeView>
    <NavLink href="grimoire" class="nav-link">
        <LucideIcon IconName="book-open" Size="18" />
        <span>Grimoire</span>
    </NavLink>

    <div class="nav-section-label">System</div>
    <NavLink href="demo" class="nav-link">
        <LucideIcon IconName="users" Size="18" />
        <span>Players</span>
    </NavLink>
    <AuthorizeView>
        <Authorized>
            <NavLink href="settings" class="nav-link">
                <LucideIcon IconName="settings" Size="18" />
                <span>Configuration</span>
            </NavLink>
            <div class="mt-auto">
                <a href="/logout" class="nav-link text-danger opacity-75">
                    <LucideIcon IconName="log-out" Size="18" />
                    <span>Sign Out</span>
                </a>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="mt-auto">
                <a href="/login" class="nav-link text-primary opacity-75">
                    <LucideIcon IconName="log-in" Size="18" />
                    <span>Sign In</span>
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</nav>
