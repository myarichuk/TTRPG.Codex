<div class="fluent-ribbon">
    <div class="ribbon-tabs">
        <div class="ribbon-tab active">Home</div>
    </div>
    <div class="ribbon-content">

        <div class="ribbon-group">
            <div class="ribbon-group-content">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
                    <span>Home</span>
                </NavLink>
                <AuthorizeView>
                    <Authorized>
                        <NavLink class="nav-link" href="campaigns">
                            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span>
                            <span>Campaigns</span>
                        </NavLink>
                    </Authorized>
                </AuthorizeView>
            </div>
            <div class="ribbon-group-title">Navigation</div>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="ribbon-group">
                    <div class="ribbon-group-content">
                        <NavLink class="nav-link" href="demo">
                            <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span>
                            <span>Demo</span>
                        </NavLink>
                    </div>
                    <div class="ribbon-group-title">Modules</div>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="ribbon-group">
            <div class="ribbon-group-content">
                <AuthorizeView>
                    <Authorized>
                        <div class="ribbon-btn user-info">
                            <span class="bi bi-person-fill" aria-hidden="true"></span>
                            <span>@context.User.Identity?.Name</span>
                        </div>
                        <a href="/logout" class="ribbon-btn">
                            <span class="bi bi-box-arrow-right" aria-hidden="true"></span>
                            <span>Log out</span>
                        </a>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="ribbon-btn">
                            <span class="bi bi-box-arrow-in-right-nav-menu" aria-hidden="true"></span>
                            <span>Log in</span>
                        </a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
            <div class="ribbon-group-title">Account</div>
        </div>

    </div>
</div>
