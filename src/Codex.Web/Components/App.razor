<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <style>
        /* Pre-Blazor boot splash: shown immediately to avoid a blank/flash during cold start. */
        #boot-splash {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at 50% 50%, #121212 0%, #080808 100%);
            color: #ffffff;
            z-index: 99999;
            font-family: system-ui, -apple-system, Segoe UI, sans-serif;
        }
        #boot-splash .boot-inner {
            width: 100%;
            max-width: 320px;
            text-align: center;
            padding: 24px;
        }
        #boot-splash .boot-mark {
            width: 64px;
            height: 64px;
            border-radius: 14px;
            margin: 0 auto 18px auto;
            display: grid;
            place-items: center;
            background: #4f6bed;
            box-shadow: 0 0 30px rgba(79, 107, 237, 0.35);
        }
        #boot-splash .boot-brand {
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            font-size: 0.95rem;
            opacity: 0.95;
            margin-bottom: 14px;
        }
        #boot-splash .boot-status {
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            opacity: 0.7;
            margin-bottom: 14px;
        }
        #boot-splash .boot-bar {
            height: 4px;
            border-radius: 2px;
            background: rgba(255, 255, 255, 0.06);
            overflow: hidden;
        }
        #boot-splash .boot-bar > div {
            height: 100%;
            width: 40%;
            background: #4f6bed;
            box-shadow: 0 0 10px rgba(79, 107, 237, 0.75);
            animation: bootSlide 2s infinite cubic-bezier(0.4, 0, 0.2, 1);
        }
        @@keyframes bootSlide {
            0% { transform: translateX(-150%); }
            100% { transform: translateX(250%); }
        }
    </style>
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Codex.Web.styles.css"]" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <div id="boot-splash" aria-label="Loading application">
        <div class="boot-inner">
            <div class="boot-mark" aria-hidden="true"></div>
            <div class="boot-brand">Codex</div>
            <div class="boot-status">Starting up...</div>
            <div class="boot-bar" aria-hidden="true"><div></div></div>
        </div>
    </div>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]" autostart="false"></script>
    <script>
        (function () {
            function removeSplash() {
                var el = document.getElementById("boot-splash");
                if (!el) return;
                el.parentNode && el.parentNode.removeChild(el);
            }

            // Make boot splash removal independent of Blazor JS interop and component render timing.
            try {
                Blazor.start().then(removeSplash).catch(removeSplash);
            } catch (e) {
                removeSplash();
            }

            // Last resort: never let it hang forever.
            window.addEventListener("load", function () {
                setTimeout(removeSplash, 8000);
            });
        })();
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
