<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <style>
        :root {
            --bg-color-main: #080808;
            --text-primary: #ffffff;
            --text-secondary: #a1a1a1;
            --text-tertiary: #404040;
            --accent-color: #4f6bed;
            --accent-glow: rgba(79, 107, 237, 0.3);
            --radius-md: 8px;
            --transition-slow: 1s cubic-bezier(0.4, 0, 0.2, 1);
        }

        #boot-splash {
            position: fixed;
            inset: 0;
            background-color: var(--bg-color-main);
            color: var(--text-primary);
            margin: 0;
            padding: 0;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background-image: radial-gradient(circle at 50% 50%, #121212 0%, #080808 100%);
            z-index: 99999;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }

        .loading-container {
            text-align: center;
            width: 100%;
            max-width: 300px;
            animation: fadeIn 1s ease-out;
        }

        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .logo-anchor {
            width: 64px;
            height: 64px;
            background: var(--accent-color);
            border-radius: 14px;
            display: grid;
            place-items: center;
            margin: 0 auto 2.5rem auto;
            box-shadow: 0 0 30px var(--accent-glow);
            position: relative;
            animation: pulse 3s infinite ease-in-out;
        }

        @@keyframes pulse {
            0%, 100% { transform: scale(1); box-shadow: 0 0 20px var(--accent-glow); }
            50% { transform: scale(1.05); box-shadow: 0 0 40px var(--accent-glow); }
        }

        .brand-name-loading {
            font-weight: 800;
            font-size: 1.1rem;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            margin-bottom: 2rem;
            color: var(--text-primary);
        }

        .progress-wrapper {
            width: 100%;
            height: 4px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 2px;
            overflow: hidden;
            margin-bottom: 1.5rem;
        }

        .progress-bar-inner {
            height: 100%;
            width: 40%;
            background: var(--accent-color);
            border-radius: 2px;
            box-shadow: 0 0 10px var(--accent-color);
            animation: slide 2s infinite cubic-bezier(0.4, 0, 0.2, 1);
        }

        @@keyframes slide {
            0% { transform: translateX(-150%); }
            100% { transform: translateX(250%); }
        }

        .status-container-loading {
            height: 20px;
            margin-bottom: 0.5rem;
        }

        .status-text-loading {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            opacity: 0;
            transition: opacity 0.5s ease;
        }

        .status-text-loading.active {
            opacity: 1;
        }

        .version-tag {
            font-size: 0.65rem;
            color: var(--text-tertiary);
            margin-top: 3rem;
            font-family: monospace;
        }
    </style>
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Codex.Web.styles.css"]" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script src="https://unpkg.com/lucide@latest"></script>
    <HeadOutlet />
</head>

<body>
    <div id="boot-splash" aria-label="Loading application">
        <div class="loading-container">
            <div class="logo-anchor">
                <i data-lucide="scroll" color="white" size="32"></i>
            </div>

            <div class="brand-name-loading">TTRPG.Codex</div>

            <div class="status-container-loading">
                <div id="status" class="status-text-loading">Initializing Systems...</div>
            </div>

            <div class="progress-wrapper">
                <div class="progress-bar-inner"></div>
            </div>

            <div class="version-tag">Core Engine v2.5.0-wasm</div>
        </div>
    </div>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]" autostart="false"></script>
    <script src="js/app-startup.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
