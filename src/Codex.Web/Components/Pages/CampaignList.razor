@page "/campaigns"
@using Codex.Persistence
@using Codex.Web.Components.Layout
@inject ICampaignRepository CampaignRepo
@inject IJSRuntime JSRuntime

<PageTitle>Campaigns</PageTitle>

<div class="app-container">
    <header class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">Campaigns</h1>
        <div class="d-flex gap-3 align-items-center" style="flex: 1; justify-content: flex-end;">
            <div class="search-wrapper">
                <LucideIcon IconName="search" Size="16" Class="search-icon" />
                <input type="text" class="search-input" placeholder="Search chronicles..." aria-label="Search chronicles">
            </div>
            <button class="btn-primary-fluent d-flex align-items-center gap-2" @onclick="CreateCampaign" disabled="@isCreating" style="white-space: nowrap;">
                @if (isCreating)
                {
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                }
                else
                {
                    <LucideIcon IconName="plus" Size="18" />
                }
                New
            </button>
        </div>
    </header>

    @if (availableSystems != null && availableSystems.Any())
    {
        <div class="filter-ribbon" role="group" aria-label="Filter campaigns by system">
            <button type="button" class="filter-chip @(selectedSystem == null ? "active" : "")" aria-pressed="@(selectedSystem == null ? "true" : "false")" @onclick="() => SelectSystem(null)">All Adventures</button>
            @foreach (var system in availableSystems)
            {
                <button type="button" class="filter-chip @(selectedSystem == system ? "active" : "")" aria-pressed="@(selectedSystem == system ? "true" : "false")" @onclick="() => SelectSystem(system)">@system</button>
            }
        </div>
    }

    @if (campaigns == null)
{
    <div class="d-flex justify-content-center my-5 py-5">
        <div class="spinner-border text-accent" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (!campaigns.Any())
{
    <div class="empty-state text-center py-5">
        <div class="mb-4">
            <LucideIcon IconName="sparkles" Size="48" Class="text-tertiary" />
        </div>
        <h3 class="mb-3">No Campaigns Found</h3>
        <p class="text-tertiary mb-5">It looks like you don't have any campaigns yet. Let's get your adventure started!</p>
        <button class="btn btn-accent px-5 d-inline-flex align-items-center justify-content-center gap-2" @onclick="CreateCampaign" disabled="@isCreating">
            @if (isCreating)
            {
                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                <span>Creating...</span>
            }
            else
            {
                <span>Create Your First Campaign</span>
            }
        </button>
    </div>
}
else
{
    <div class="campaign-grid">
        @foreach (var campaign in campaigns)
        {
            var isDnd = campaign.System.Contains("DnD") || campaign.System == "D&D 5E";
            var artUrl = isDnd ? "https://images.unsplash.com/photo-1519074063912-ad2fe3f51904?auto=format&fit=crop&q=80&w=800" : "https://images.unsplash.com/photo-1605806616949-1e87b487fc2f?auto=format&fit=crop&q=80&w=800";
            <div class="campaign-card">
                <div class="art-container">
                    <div class="art-fallback">
                        <LucideIcon IconName="@(isDnd ? "swords" : "anchor")" Size="32" />
                    </div>
                    <span class="system-badge">@campaign.System</span>
                    <img src="@artUrl" alt="" loading="lazy">
                </div>
                <div class="card-content">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h3 class="card-title mb-0">@campaign.Name</h3>
                        <button class="btn-sparkle" aria-label="Oracle Insights for @campaign.Name" title="Oracle Insights"><LucideIcon IconName="sparkles" Size="14" /></button>
                    </div>
                    <div class="card-meta">
                        <span class="meta-item"><LucideIcon IconName="calendar" Size="12" /> Active</span>
                    </div>
                    <p class="card-text small text-secondary">
                        @if (!string.IsNullOrWhiteSpace(campaign.Description))
                        {
                            @campaign.Description
                        }
                        else
                        {
                            <span class="opacity-50 italic">No chronicle notes scribed yet.</span>
                        }
                    </p>
                    <div class="mt-auto pt-3 border-top border-secondary border-opacity-10">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="text-tertiary small">Last session: @campaign.UpdatedAt.ToString("MMM dd")</span>
                            <button class="btn-manage-fluence d-flex align-items-center gap-2" aria-label="Delete @campaign.Name" @onclick="() => DeleteCampaign(campaign.Id, campaign.Name)" title="Delete Campaign" style="color: var(--bs-danger);">
                                <LucideIcon IconName="trash-2" Size="14" />
                            </button>
                            <button class="btn-manage-fluence" aria-label="Manage @campaign.Name">
                                <LucideIcon IconName="settings" Size="14" Class="anim-rotate" />
                                <span>Manage</span>
                            </button>
                        </div>
                        <button class="btn-session-fluence w-100" @onclick:stopPropagation="true">
                            <LucideIcon IconName="dices" Size="16" Class="anim-pulse" />
                            <span>New Session</span>
                        </button>
                    </div>
                </div>
            </div>
        }

        <button class="campaign-card" aria-label="Initiate New Story" style="border-style: dashed; background: transparent; cursor: pointer; justify-content: center; align-items: center; min-height: 380px;" @onclick="CreateCampaign" disabled="@isCreating">
            <div class="text-center p-5">
                <div style="background: var(--fluent-surface-secondary); width: 48px; height: 48px; border-radius: 50%; display: grid; place-items: center; margin: 0 auto 1rem auto;">
                    @if (isCreating)
                    {
                        <span class="spinner-border text-secondary" role="status" aria-hidden="true" style="width: 24px; height: 24px;"></span>
                    }
                    else
                    {
                        <LucideIcon IconName="plus" Size="24" Class="text-secondary" />
                    }
                </div>
                <h4 class="h6 text-secondary">Initiate New Story</h4>
                <p class="small text-tertiary">Select a template or start blank.</p>
            </div>
        </button>
    </div>
    }
</div>

@code {
    private IEnumerable<CampaignDocument>? campaigns;
    private List<string>? availableSystems;
    private string? selectedSystem;
    private bool isCreating = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var all = await CampaignRepo.GetAllAsync();
        availableSystems = all.Select(c => c.System).Distinct().OrderBy(s => s).ToList();
        
        if (selectedSystem != null)
        {
            campaigns = all.Where(c => c.System == selectedSystem);
        }
        else
        {
            campaigns = all;
        }
    }

    private async Task SelectSystem(string? system)
    {
        selectedSystem = system;
        await LoadData();
    }

    private async Task DeleteCampaign(string id, string name)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the campaign '{name}'? This action cannot be undone.");
        if (!confirm) return;

        await CampaignRepo.DeleteAsync(id);
        await LoadData();
    }

    private async Task CreateCampaign()
    {
        isCreating = true;
        try
        {
            var doc = new CampaignDocument
            {
                Id = Guid.NewGuid().ToString(),
                Name = "Unnamed Legend",
                System = "D&D 5E",
                UpdatedAt = DateTime.UtcNow
            };
            await CampaignRepo.SaveAsync(doc);
            await LoadData();
        }
        finally
        {
            isCreating = false;
        }
    }
}
