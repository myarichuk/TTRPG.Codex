@page "/campaigns"
@using Codex.Persistence
@inject ICampaignRepository CampaignRepo

<PageTitle>Campaigns</PageTitle>

<div class="container mt-4">
    <h1 class="mb-4">Campaigns</h1>

    @if (campaigns == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!campaigns.Any())
    {
        <div class="card p-5 text-center mb-4">
            <div class="mb-3">
                <span class="bi bi-journal-plus" style="font-size: 3rem; color: var(--text-secondary);" aria-hidden="true"></span>
            </div>
            <h3 class="mb-3">No Campaigns Found</h3>
            <p class="text-muted mb-4">It looks like you don't have any campaigns yet. Let's get your adventure started!</p>
            <div>
                <button class="btn btn-primary btn-lg" @onclick="CreateCampaign" disabled="@isCreating">
                    @if (isCreating)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Creating...</span>
                    }
                    else
                    {
                        <span class="bi bi-plus-circle me-2" aria-hidden="true"></span>
                        <span>Create Your First Campaign</span>
                    }
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var campaign in campaigns)
            {
                <div class="col-md-4 mb-3">
                    <div class="card p-3 h-100">
                        <h5>@campaign.Name</h5>
                        <h6 class="text-muted mb-0">@campaign.System</h6>
                    </div>
                </div>
            }
        </div>

        <button class="btn btn-primary mt-3" @onclick="CreateCampaign" disabled="@isCreating">
            @if (isCreating)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                <span>Creating...</span>
            }
            else
            {
                <span class="bi bi-plus-circle me-2" aria-hidden="true"></span>
                <span>Create New Campaign</span>
            }
        </button>
    }
</div>

@code {
    private IEnumerable<CampaignDocument>? campaigns;
    private bool isCreating = false;

    protected override async Task OnInitializedAsync()
    {
        campaigns = await CampaignRepo.GetAllAsync();
    }

    private async Task CreateCampaign()
    {
        isCreating = true;
        try
        {
            var doc = new CampaignDocument
            {
                Id = Guid.NewGuid().ToString(),
                Name = "New Campaign",
                System = "DnD5e"
            };
            await CampaignRepo.SaveAsync(doc);
            campaigns = await CampaignRepo.GetAllAsync();
        }
        finally
        {
            isCreating = false;
        }
    }
}
