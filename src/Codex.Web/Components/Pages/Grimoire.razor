@page "/grimoire"
@using Codex.Web.Components.Layout

<PageTitle>Grimoire | TTRPG.Codex</PageTitle>

<!-- Updated Header with Action Group -->
<header class="d-flex justify-content-between align-items-center mb-4">
    <div class="search-container me-4">
        <LucideIcon IconName="search" Size="18" Class="search-icon" />
        <input type="text" class="search-input" placeholder="Search spells, artifacts, or lore..." aria-label="Search spells, artifacts, or lore">
    </div>
    <div class="action-group">
        <button class="ai-sparkle-btn" title="AI Generate Lore">
            <LucideIcon IconName="sparkles" Size="16" />
            Generate
        </button>
        <button class="btn-add">
            <LucideIcon IconName="plus" Size="18" />
            Add Entry
        </button>
    </div>
</header>

<div class="filter-bar">
    <div class="category-chip active"><LucideIcon IconName="layers" Size="14" /> All Entry</div>
    <div class="category-chip"><LucideIcon IconName="flame" Size="14" /> Spells</div>
    <div class="category-chip"><LucideIcon IconName="gem" Size="14" /> Artifacts</div>
    <div class="category-chip"><LucideIcon IconName="map-pin" Size="14" /> Locations</div>
    <div class="category-chip"><LucideIcon IconName="skull" Size="14" /> Bestiary</div>
</div>

@if (loreEntries == null || !loreEntries.Any())
{
    <div class="empty-state-container">
        <div class="empty-state-icon">
            <LucideIcon IconName="book" Size="48" />
        </div>
        <h3>The Grimoire is Silent</h3>
        <p>No spells, artifacts, or chronicles have been inscribed yet. Scribe your first entry to begin your hoard of knowledge.</p>
        <button class="btn-add mt-3" @onclick="CreateFirstEntry">
            <LucideIcon IconName="plus" Size="18" />
            Scribe First Entry
        </button>
    </div>
}
else
{
    <h2 class="h6 text-tertiary mb-3 fw-bold text-uppercase" style="letter-spacing: 0.1em;">Pinned Chronicles</h2>
    <div class="featured-lore">
        @foreach (var entry in loreEntries.Where(e => e.IsPinned))
        {
            <div class="lore-card">
                <div class="icon-box"><LucideIcon IconName="@entry.Icon" Size="20" /></div>
                <h3 class="lore-title">@entry.Title</h3>
                <p class="lore-desc">@entry.Description</p>
                <div class="mt-auto d-flex justify-content-between align-items-center">
                    <span class="tag-pill">@entry.Tag</span>
                    <button class="btn-action" aria-label="View details for @entry.Title" title="View details"><LucideIcon IconName="external-link" Size="14" /></button>
                </div>
            </div>
        }
    </div>

    <div class="d-flex justify-content-between align-items-end mb-3">
        <h2 class="h6 text-tertiary mb-0 fw-bold text-uppercase" style="letter-spacing: 0.1em;">Recent Lore Entries</h2>
        <a href="#" class="text-accent small text-decoration-none">View Full Library →</a>
    </div>

    <div class="lore-table-wrapper">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Date Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in loreEntries)
                {
                    <tr>
                        <td class="fw-medium text-white">@entry.Title</td>
                        <td><span class="text-secondary small">@entry.Category</span></td>
                        <td><span class="text-tertiary small">@entry.CreatedAt.ToString("MMM dd, yyyy")</span></td>
                        <td class="text-end">
                            <button class="btn-action mx-1" aria-label="Edit @entry.Title" title="Edit"><LucideIcon IconName="edit-3" Size="16" /></button>
                            <button class="btn-action mx-1" aria-label="Delete @entry.Title" title="Delete"><LucideIcon IconName="trash-2" Size="16" /></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<LoreEntry>? loreEntries;

    protected override void OnInitialized()
    {
        // Currently empty to represent a clean state for the user.
        // In a real scenario, this would load from a repository.
        loreEntries = new List<LoreEntry>();
    }

    private void CreateFirstEntry()
    {
        // Placeholder for creation logic
    }

    public class LoreEntry
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public string Category { get; set; } = "";
        public string Tag { get; set; } = "";
        public string Icon { get; set; } = "book";
        public DateTime CreatedAt { get; set; } = DateTime.Now;
        public bool IsPinned { get; set; }
    }
}
