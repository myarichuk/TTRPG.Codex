@page "/"
@using Codex.Persistence
@using Codex.Web.Components.Layout
@using System.Net.Http.Json
@inject ICampaignRepository CampaignRepo
@inject ICharacterRepository CharacterRepo
@inject HttpClient Http
@inject IJSRuntime JSRuntime

<PageTitle>Dashboard | TTRPG.Codex</PageTitle>

@if (campaigns == null)
{
    <div class="d-flex justify-content-center my-5 py-5">
        <div class="spinner-border text-accent" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="animate-fade">
        <header class="d-flex justify-content-between align-items-start">
            <div>
                <h1>Your Worlds</h1>
                <p class="page-subtitle">Welcome back. You have <span>@campaigns.Count()</span> active @(campaigns.Count() == 1 ? "campaign" : "campaigns").</p>
            </div>
            <button class="btn btn-accent d-flex align-items-center gap-2">
                <LucideIcon IconName="plus" Size="20" />
                <span>Create Adventure</span>
            </button>
        </header>

        <div class="dashboard-grid">
            @foreach (var campaign in campaigns)
            {
                <div class="campaign-card">
                    <div class="art-preview">
                        <LucideIcon IconName="@(campaign.System.Contains("DnD") ? "swords" : "anchor")" Size="40" Class="text-white opacity-25" />
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h3 class="card-title mb-0">@campaign.Name</h3>
                            <button class="btn-delete-fluence" aria-label="Delete @campaign.Name" @onclick="() => DeleteCampaign(campaign.Id, campaign.Name)" title="Destroy Chronicle">
                                <LucideIcon IconName="trash-2" Size="14" />
                            </button>
                        </div>
                        <p class="card-text">@(string.IsNullOrWhiteSpace(campaign.Description) ? "No description recorded." : campaign.Description)</p>
                    </div>
                </div>
            }

            @if (campaigns.Count() < 3)
            {
                <button type="button" class="campaign-card card-empty w-100 text-center" aria-label="New Storyline" @onclick="ExpandAI">
                    <div class="card-body">
                        <LucideIcon IconName="sparkles" Size="32" Class="sparkle-icon" />
                        <h3 class="card-title">New Storyline</h3>
                        <p class="card-text">Start with a blank canvas or let the Oracle suggest a spark.</p>
                        <div class="mt-4">
                            <span class="btn btn-sm btn-outline-secondary px-4" style="border-radius: 20px; font-size: 0.75rem;">Browse Hub</span>
                        </div>
                    </div>
                </button>
            }
        </div>

        <section>
            <div class="section-header">
                <h2 class="h5 mb-0 fw-bold">Recent Archives</h2>
                <div class="archive-controls">
                    <button class="control-btn @(!sortByCreated ? "active" : "")" aria-pressed="@(!sortByCreated ? "true" : "false")" @onclick="() => SetSort(false)">Modified</button>
                    <button class="control-btn @(sortByCreated ? "active" : "")" aria-pressed="@(sortByCreated ? "true" : "false")" @onclick="() => SetSort(true)">Newest</button>
                </div>
            </div>

            <div class="fluent-table-wrapper">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Subject</th>
                            <th>Last Modified</th>
                            <th style="width: 40px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (characters == null)
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4">
                                    <div class="spinner-border spinner-border-sm text-accent" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        else if (characters.Any())
                        {
                            @foreach (var character in characters)
                            {
                                <tr>
                                    <td>@character.Name</td>
                                    <td>Character</td>
                                    <td>@character.UpdatedAt.ToString("MMM dd, yyyy")</td>
                                    <td><LucideIcon IconName="chevron-right" Size="16" Class="text-tertiary" /></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 opacity-25" style="font-style: italic;">
                                    Your grimoire is empty. Begin an adventure to see history here.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-3 text-end">
                <a href="demo" class="text-accent small text-decoration-none fw-600">View all lore →</a>
            </div>
        </section>
    </div>

    <!-- AI Toast Interaction -->
    <div id="ai-toast" style="display: @(showToast ? "block" : "none")">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="small fw-bold text-accent d-flex align-items-center gap-2">
                <LucideIcon IconName="sparkles" Size="14" /> Oracle Suggestion
            </span>
            <button class="btn-close btn-close-white" style="font-size: 0.6rem;" aria-label="Dismiss Oracle Suggestion" @onclick="HideToast"></button>
        </div>
        <div class="small text-secondary mb-4" style="line-height: 1.6;">
            @if (isConsulting)
            {
                <div class="d-flex align-items-center gap-2 opacity-50">
                    <div class="spinner-border spinner-border-sm" role="status"></div> Consulting the archives...
                </div>
            }
            else
            {
                @toastContent
            }
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm w-100 btn-outline-secondary" style="font-size: 0.75rem;" @onclick="HideToast">Dismiss</button>
            <button class="btn btn-sm w-100 btn-accent" style="font-size: 0.75rem;" @onclick="HideToast">Use This</button>
        </div>
    </div>
}

@code {
    private IEnumerable<CampaignDocument>? campaigns;
    private IEnumerable<CharacterDocument>? characters;
    private bool sortByCreated = false;

    private bool showToast = false;
    private bool isConsulting = false;
    private string toastContent = "";

    protected override async Task OnInitializedAsync()
    {
        campaigns = await CampaignRepo.GetAllAsync();
        await LoadCharacters();
    }

    private async Task SetSort(bool newestFirst)
    {
        if (sortByCreated == newestFirst) return;
        sortByCreated = newestFirst;
        await LoadCharacters();
    }

    private async Task LoadCharacters()
    {
        characters = null; // Show spinner
        characters = await CharacterRepo.GetAllAsync(5, sortByCreated);
    }

    private async Task DeleteCampaign(string id, string name)
    {
        bool confirm = await JSRuntime.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the campaign '{name}'? This action cannot be undone.");
        if (!confirm) return;

        await CampaignRepo.DeleteAsync(id);
        campaigns = await CampaignRepo.GetAllAsync();
        StateHasChanged();
    }

    private async Task ExpandAI()
    {
        showToast = true;
        isConsulting = true;
        toastContent = "";
        StateHasChanged();

        var apiKey = ""; // Keep empty as in user prompt, or configure it elsewhere
        var url = $"https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key={apiKey}";

        try
        {
            var requestBody = new
            {
                contents = new[]
                {
                    new
                    {
                        parts = new[]
                        {
                            new { text = "Give me a 1-sentence mysterious TTRPG campaign hook." }
                        }
                    }
                },
                systemInstruction = new
                {
                    parts = new[]
                    {
                        new { text = "You are a creative TTRPG storyteller. Be brief and punchy." }
                    }
                }
            };

            var response = await Http.PostAsJsonAsync(url, requestBody);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
                toastContent = result.GetProperty("candidates")[0].GetProperty("content").GetProperty("parts")[0].GetProperty("text").GetString() ?? "The weave is silent today.";
            }
            else
            {
                toastContent = "The weave is silent today.";
            }
        }
        catch
        {
            toastContent = "Connection to the Oracle lost.";
        }
        finally
        {
            isConsulting = false;
            StateHasChanged();
        }
    }

    private void HideToast()
    {
        showToast = false;
    }
}
