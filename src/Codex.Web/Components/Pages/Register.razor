@page "/register"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Identity
@using Codex.Persistence
@using Codex.Web.Components.Layout
@layout AuthLayout
@inject IUserRepository UserRepository
@inject NavigationManager NavManager

<PageTitle>Register | TTRPG.Codex</PageTitle>

<div class="login-card">
    <div class="brand-anchor">
        <div class="logo-mark">
            <LucideIcon IconName="scroll" Size="32" />
        </div>
        <div class="brand-name">Codex</div>
    </div>

    <EditForm Model="@Model" OnValidSubmit="HandleRegister" FormName="RegisterForm">
        <DataAnnotationsValidator />

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger small p-2 mb-3 rounded" style="background-color: rgba(220, 53, 69, 0.1); border-color: rgba(220, 53, 69, 0.2); color: #ff6b6b;">@ErrorMessage</div>
        }

        <div class="mb-3 text-start">
            <label for="username" class="form-label small text-secondary">Account Username</label>
            <InputText id="username" class="form-control w-100" placeholder="dm" @bind-Value="Model!.Username" />
        </div>

        <div class="mb-3 text-start">
            <label for="password" class="form-label small text-secondary">Secret Key</label>
            <InputText id="password" type="password" class="form-control w-100" placeholder="••••••••" @bind-Value="Model!.Password" />
        </div>

        <div class="mb-4 text-start">
            <label for="confirmPassword" class="form-label small text-secondary">Confirm Secret Key</label>
            <InputText id="confirmPassword" type="password" class="form-control w-100" placeholder="••••••••" @bind-Value="Model!.ConfirmPassword" />
        </div>

        <button type="submit" class="btn-accent w-100 mt-2">Initiate Account</button>
    </EditForm>

    <div class="footer-links">
        Already a Storyteller? <a href="/login" class="text-accent">Enter Grimoire</a>
    </div>
</div>

@code {
    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromForm]
    public RegisterModel? Model { get; set; }

    protected override void OnInitialized()
    {
        Model ??= new();
    }

    public string? ErrorMessage { get; set; }

    private async Task HandleRegister()
    {
        if (HttpContext == null || Model == null)
        {
            ErrorMessage = "HttpContext is not available. Please ensure you are registering from a static rendered page.";
            return;
        }

        if (Model.Password != Model.ConfirmPassword)
        {
            ErrorMessage = "Passwords do not match.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Model.Username) || string.IsNullOrWhiteSpace(Model.Password))
        {
            ErrorMessage = "Username and Password are required.";
            return;
        }

        var existingUser = await UserRepository.GetUserByUsernameAsync(Model.Username);

        if (existingUser != null)
        {
            ErrorMessage = "Username is already taken.";
            return;
        }

        var user = new UserDocument
        {
            Id = Guid.NewGuid().ToString(),
            Username = Model.Username,
            Roles = new List<string> { "Player" }
        };

        if (Model.Username.ToLower() == "dm")
        {
            user.Roles.Add("DM");
        }

        var hasher = new PasswordHasher<UserDocument>();
        user.PasswordHash = hasher.HashPassword(user, Model.Password);

        await UserRepository.CreateUserAsync(user);

        // Sign the user in immediately after registering
        var claims = new List<Claim>
        {
            new Claim(ClaimTypes.Name, user.Username),
            new Claim(ClaimTypes.NameIdentifier, user.Id)
        };

        foreach (var role in user.Roles)
        {
            claims.Add(new Claim(ClaimTypes.Role, role));
        }

        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        await HttpContext.SignInAsync(CookieAuthenticationDefaults.AuthenticationScheme, principal);

        NavManager.NavigateTo("/", forceLoad: true);
    }

    public class RegisterModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
