@page "/demo"
@using Codex.Core
@using DefaultEcs
@using Codex.Systems.DnD5e
@using Codex.Plugin.Abstractions
@using Codex.Core.Components
@inject CodexWorld World

<PageTitle>Character Demo</PageTitle>

<div class="container mt-4">
    <h1 class="mb-4">Character Demo</h1>

    <button class="btn btn-primary px-4 shadow-sm" @onclick="CreateTestEntity">Create Test Entity</button>
    <br/><br/>

    @if (entity.IsAlive)
    {
        <div class="card p-4 mt-3 shadow-sm border-0" style="max-width: 400px;">
            @if (entity.Has<ResourcePoolComponent>())
            {
                var pool = entity.Get<ResourcePoolComponent>();
                <h5 class="mb-3">Entity Status</h5>
                <p><strong>Current HP:</strong> @pool.Get("HP") / @pool.Get("HP_Max")</p>
                <button class="btn btn-danger px-4 shadow-sm mt-2" @onclick="TakeDamage">Take 1 Damage</button>
            }
        </div>
    }
    else
    {
        <p class="text-muted mt-3">No entity created yet.</p>
    }
</div>

@code {
    private Entity entity;

    private void CreateTestEntity()
    {
        entity = World.CreateEntity();
        var pool = new ResourcePoolComponent();
        pool.Set("HP", 10);
        pool.Set("HP_Max", 10);
        entity.Set(pool);
    }

    private void TakeDamage()
    {
        if (entity.IsAlive)
        {
            entity.Set(new DamageEvent { Amount = 1 });
            World.Tick(0.016f);
        }
    }
}
