<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Codex.Authoring.ViewModels"
             x:Class="Codex.Authoring.Views.EditPackDialogView"
             x:DataType="vm:EditPackDialogViewModel"
             Width="400" Height="400">

    <Grid RowDefinitions="Auto,*" Margin="20">
        <!-- Header -->
        <TextBlock Text="Edit Pack Manifest" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- Content -->
        <StackPanel Grid.Row="1" Spacing="15">
            <TextBlock Text="System" FontWeight="SemiBold"/>
            <TextBox Text="{Binding SystemId}" IsReadOnly="True" IsEnabled="False" UseFloatingWatermark="True" Watermark="Game System ID" />

            <TextBlock Text="Pack Details" FontWeight="SemiBold" Margin="0,10,0,0"/>

            <TextBox Watermark="Pack Name"
                     Text="{Binding PackName}"
                     UseFloatingWatermark="True"/>

            <TextBox Watermark="Description"
                     Text="{Binding PackDescription}"
                     AcceptsReturn="True"
                     Height="100"
                     UseFloatingWatermark="True"/>

            <TextBox Watermark="Thumbnail Path (optional)"
                     Text="{Binding ThumbnailPath}"
                     UseFloatingWatermark="True"/>
        </StackPanel>
    </Grid>
</UserControl>
